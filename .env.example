# ─── Required ─────────────────────────────────────────────────────────
# Facebook Page access token (must be a Page token, not a User token)
# Get it at: https://developers.facebook.com/tools/explorer/
# Use the "Get Page Access Token" button under your app
FB_PAGE_ACCESS_TOKEN=your_page_access_token_here

# Your Facebook Page ID (numeric, e.g. 1234567890)
FB_PAGE_ID=your_page_id_here

# Your World Monitor deployment URL (no trailing slash)
WORLDMONITOR_API_URL=https://worldmonitor-oshada.vercel.app

# ─── Optional Tuning ──────────────────────────────────────────────────
# Polling interval in milliseconds (default: 60000 = 1 min)
POLL_INTERVAL_MS=60000

# Max posts per regular batch (default: 3)
MAX_POSTS_PER_BATCH=3

# Max Facebook API calls per rolling hour (FB allows 200; we stop at 180)
MAX_FB_CALLS_PER_HOUR=180

# HTTP port (Render sets this automatically)
PORT=3000

# ─── Keep-Alive (prevents Render free tier from sleeping) ─────────────
# Set this to your own Render service URL after first deploy
# e.g. https://worldmonitor-fb-bot.onrender.com/health
KEEP_ALIVE_URL=

# Keep-alive ping interval in ms (default: 840000 = 14 min)
KEEP_ALIVE_INTERVAL=840000

# ─── Development / Testing ────────────────────────────────────────────
# Set to "true" to log what WOULD be posted without actually posting
DRY_RUN=false
